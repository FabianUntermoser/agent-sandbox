# Container-local bash init, sourced from ~/.bashrc inside the sandbox.
# The host ~/.bashrc is distro-specific (Arch/Manjaro) and can't be mounted
# here, so this provides just enough for the portable dotfiles to load.

: "${XDG_CONFIG_HOME:=$HOME/.config}"

[[ $- != *i* ]] && return

# --- shopt ---
shopt -s checkwinsize
shopt -s histappend
shopt -s expand_aliases

# --- history ---
export HISTFILE="$HOME/.bash_history"
export HISTCONTROL=ignoreboth

# --- completion ---
[ -r /usr/share/bash-completion/bash_completion ] && . /usr/share/bash-completion/bash_completion

# --- prompt ---
case ${TERM} in
xterm*|rxvt*|Eterm*|aterm|kterm|gnome*|interix|konsole*)
	PROMPT_COMMAND='echo -ne "\033]0;sandbox: ${PWD/#$HOME/\~}\007"'
	;;
screen*)
	PROMPT_COMMAND='echo -ne "\033_${PWD/#$HOME/\~}\033\\"'
	;;
esac

PS1='\[\033[01;32m\][sandbox \[\033[01;37m\]\W\[\033[01;32m\]]\$\[\033[00m\] '

# --- aliases ---
source_file() { [ -r "$1" ] && source "$1"; }
source_file "$XDG_CONFIG_HOME/aliasrc"
source_file "$XDG_CONFIG_HOME/zsh/aliasrc"

# --- fzf ---
source_file "$XDG_CONFIG_HOME/fzfrc"
source_file "/usr/share/fzf/completion.bash" 2>/dev/null
source_file "/usr/share/fzf/key-bindings.bash" 2>/dev/null

# --- vim mode + prevent ^S freeze ---
stty -ixon
set -o vi

# --- ex: archive extractor ---
ex() {
	if [ -f "$1" ]; then
		case "$1" in
		*.tar.bz2|*.tar.gz|*.bz2|*.gz|*.tar|*.tbz2|*.tgz) tar xf "$1" ;;
		*.rar) unrar x "$1" ;;
		*.zip) unzip "$1" ;;
		*.Z) uncompress "$1" ;;
		*.7z) 7z x "$1" ;;
		*) echo "'$1' cannot be extracted via ex()" ;;
		esac
	else
		echo "'$1' is not a valid file"
	fi
}
